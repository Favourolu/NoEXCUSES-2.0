function render(){
var app=document.getElementById(“app”);
app.innerHTML=””;
if(S.page===“auth”||!S.user){app.appendChild(authPage());return;}
var shell=d(””);shell.style.cssText=“display:flex;flex-direction:column;height:100vh;height:100dvh”;
var tb=d(“topbar”);
var logo=d(“logo”);logo.innerHTML=“No<span class='logo-accent'>Excuses</span>”;
var oc=overCount(),oa=isOverAll();
var bc=oa?”#f87171”:oc>0?”#fb923c”:”#34d399”;
var bt=oa?“Over budget”:oc>0?oc+” over”:“On track”;
var badge=d(“badge”,bt);badge.style.color=bc;
tb.appendChild(logo);tb.appendChild(badge);shell.appendChild(tb);
var pages={home:homePage,log:logPage,history:historyPage,settings:settingsPage};
shell.appendChild((pages[S.page]||homePage)());
shell.appendChild(bottomNav());
if(S.guilt)shell.appendChild(guiltOverlay());
app.appendChild(shell);
}

function start(){
if(!initSB()){render();return;}
checkSession();
}

